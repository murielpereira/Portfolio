{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/verificar-entregas",
      "schedule": "0 5,16 * * *"
    }
  ],
  "crons": [
    {
      "path": "/processar-fila",
      "schedule": "*/10 * * * *" 
    }
  ]
}