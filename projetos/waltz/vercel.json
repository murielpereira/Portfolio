{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { 
      "src": "/", 
      "dest": "/public/index.html" 
    },
    { 
      "src": "/(.*\\.(js|css|png|jpg|jpeg|svg|html|ico))", 
      "dest": "/public/$1" 
    },
    { 
      "src": "/(.*)", 
      "dest": "/server.js" 
    }
  ]
}